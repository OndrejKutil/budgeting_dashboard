# Frontend environment variables — copy to `.env` and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

VITE_API_BASE_URL=http://localhost:8000   # Base URL of the backend API
VITE_API_KEY=your-app-api-key             # Must match the backend's API_KEY (sent as the X-API-KEY header)
