# Backend environment variables — copy to `.env` and fill in real values.
# Loaded by helper/environment.py via python-dotenv. Never commit the real `.env`.

# --- Supabase (Dashboard → Project Settings → API / Database) ---
PROJECT_URL=https://your-project-ref.supabase.co   # Supabase project URL
ANON_KEY=your-anon-public-key                      # Anon/public key — used for user-scoped queries (RLS enforced)
SERVICE_ROLE_KEY=your-service-role-key             # Service role key — account deletion ONLY (bypasses RLS, keep secret)
SUPABASE_JWT_SECRET=your-jwt-secret                # Secret used to verify user access tokens (JWTs)

# --- App auth keys (generate strong random strings) ---
API_KEY=your-app-api-key                           # App-level key required on every request (X-API-KEY header)
ADMIN_KEY=your-admin-key                           # Extra key for admin-only endpoints (e.g. log access)

# --- CORS ---
FRONTEND_URL=http://localhost:5173                 # Allowed frontend origin(s); comma-separated for multiple

# --- Misc ---
DEVELOPMENT_MODE=False                             # Set True for verbose/dev-specific behavior

# --- Optional: only needed to run tests/manual.py (manual login test) ---
# EMAIL=you@example.com
# PASSWORD=your-test-account-password
